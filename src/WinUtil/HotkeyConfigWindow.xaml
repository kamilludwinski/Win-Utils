<Window x:Class="WinUtil.HotkeyConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Global hotkey"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBrush}">
    <Border Padding="20" Background="{DynamicResource SurfaceBrush}">
        <StackPanel>
            <TextBlock Text="Press a key combination"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"
                       Text="Hold modifiers (Ctrl, Alt, Shift, Win) and press the final key. Esc cancels." />

            <Border BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16,20"
                    Margin="0,0,0,16"
                    MinHeight="72"
                    Background="{DynamicResource SurfaceAltBrush}">
                <TextBlock x:Name="HotkeyDisplayText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Text="…"
                           VerticalAlignment="Center" />
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        IsCancel="True"
                        Style="{StaticResource ToolbarButton}"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button x:Name="OkButton"
                        Content="Save"
                        IsDefault="True"
                        Style="{StaticResource ToolbarButton}"
                        IsEnabled="False"
                        Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
